{
    "manifest_version": 3,
    "name": "Ghost Hunter",
    "version": "1.0.0",
    "description": "Extension for Ghost Hunter",
    "icons": {
        "32": "/assets/icon02.png",
        "48": "/assets/icon02.png"
    },
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "scripting",
        "storage",
        "identity",
        "webRequest"
    ],
    "background": {
        "service_worker": "service-worker.js"
    },
    "host_permissions": [
        "https://*/*",
        "http://*/*",
        "https://*.supabase.co/*"
    ]
}